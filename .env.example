# ============================================================================
# Redis Configuration
# ============================================================================

REDIS_PORT=6379
REDIS_PASSWORD=your_secure_password_here
REDIS_MAXMEMORY=2gb
REDIS_MAXCLIENTS=10000

# Docker resource limits
REDIS_MEMORY_LIMIT=3G
REDIS_MEMORY_RESERVATION=1G

# Connection URL for your app:
# redis://:your_secure_password_here@<host>:6379/0
